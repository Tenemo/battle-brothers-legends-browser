{
  "name": "battle-brothers-legends-perks-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "husky",
    "predev": "node ./scripts/ensure-legends-reference.mjs",
    "dev": "vite",
    "predev:test": "node ./scripts/ensure-legends-reference.mjs",
    "dev:test": "vite --host 127.0.0.1 --port 4173",
    "prebuild": "node ./scripts/ensure-legends-reference.mjs",
    "build": "tsc -b && vite build",
    "build:netlify": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "tsc": "tsc -b",
    "lint": "eslint .",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "ensure:legends-reference": "node ./scripts/ensure-legends-reference.mjs",
    "sync:icons": "node ./scripts/sync-legends-icons.mjs",
    "sync:perks": "node ./scripts/sync-legends-perks.mjs"
  },
  "dependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@resvg/resvg-js": "^2.6.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@netlify/edge-functions": "^3.0.6",
    "@netlify/functions": "^5.2.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
